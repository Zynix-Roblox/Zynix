    if input.KeyCode == Enum.KeyCode[Config.Visuals.thirdPerson.shoulderSwapKey] and Config.Visuals.thirdPerson.enabled then
        shoulderSide = shoulderSide * -1
    end
end)

-- Aimbot
local aimTarget = nil; local silentAimOriginalCF = nil; local silentAimSnapTime = 0
local function updateAimbot(deltaTime)
    if not (Config.SilentAim or Config.Aimbot.enabled) then return end
    if Config.Aimbot.holdKey and Config.Aimbot.holdKey ~= "" then
        local key = Enum.KeyCode[Config.Aimbot.holdKey]
        if key and not UserInputService:IsKeyDown(key) and not UserInputService:IsMouseButtonPressed(key) then
            aimTarget = nil; return
        end
    end
    local fov = Config.Aimbot.enabled and Config.Aimbot.fov or 9999
    local target = getClosestPlayerToCursor(fov, Config.Aimbot.teamCheck, Config.Aimbot.wallCheck, Config.Aimbot.targetPriority)
    if target and target.Character then
        aimTarget = target
        local part = getTargetPart(target.Character, Config.Aimbot.targetPriority)
        if part then
            local targetPos = part.Position
            if Config.Aimbot.prediction then targetPos = targetPos + (part.Velocity or Vector3.new()) * Config.Aimbot.predictionAmount end
            local camPos = Camera.CFrame.Position; local desiredCF = CFrame.new(camPos, targetPos)
            if Config.SilentAim and tick() - silentAimSnapTime > 0.15 then
                silentAimOriginalCF = Camera.CFrame; Camera.CFrame = desiredCF; silentAimSnapTime = tick()
                task.delay(0.15, function() if silentAimOriginalCF then Camera.CFrame = silentAimOriginalCF end end)
            elseif Config.Aimbot.enabled then
                local smoothness = Config.Aimbot.smoothness
                if smoothness <= 1 then Camera.CFrame = desiredCF
                else
                    local factor = 1 - (1 - 1/smoothness) ^ (deltaTime * 60); factor = math.clamp(factor, 0, 1)
                    Camera.CFrame = Camera.CFrame:Lerp(desiredCF, factor)
                end
                if Config.Aimbot.autoShoot then
                    VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true, game, 1); task.wait(0.02)
                    VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1)
                end
            end
        end
    else aimTarget = nil end
end

-- Triggerbot
local lastTriggerTime = 0
local function updateTriggerbot()
    if not Config.Triggerbot.enabled then return end
    if tick() - lastTriggerTime < Config.Triggerbot.delay then return end
    local target = getPlayerFromMouse()
    if target and isValidTarget(target, Config.Aimbot.teamCheck, Config.Aimbot.wallCheck) then
        VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true, game, 1); task.wait(0.02)
        VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1)
        lastTriggerTime = tick()
    end
end

-- Hitbox Expander
local function updateHitboxExpander()
    if not Config.HitboxExpander.enabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                for _, partName in ipairs({"Head","UpperTorso","LowerTorso","HumanoidRootPart"}) do
                    local part = player.Character:FindFirstChild(partName)
                    if part and part:IsA("BasePart") then
                        local orig = part:GetAttribute("OriginalSize")
                        if orig then part.Size = orig; part:SetAttribute("OriginalSize", nil) end
                    end
                end
            end
        end
        return
    end
    local scale = Config.HitboxExpander.scale
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            for _, partName in ipairs({"Head","UpperTorso","LowerTorso","HumanoidRootPart"}) do
                local part = player.Character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    local orig = part:GetAttribute("OriginalSize")
                    if not orig then orig = part.Size; part:SetAttribute("OriginalSize", orig) end
                    part.Size = orig * scale
                end
            end
        end
    end
end

-- KillAura
local function updateKillAura(deltaTime)
    if not Config.KillAura.enabled then return end
    local char = LocalPlayer.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    if Config.KillAura.noclip then
        for _, part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
    end
    local nearestTarget, nearestDist = nil, Config.KillAura.range
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and isValidTarget(player, Config.Aimbot.teamCheck, Config.Aimbot.wallCheck) then
            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local dist = (root.Position - targetRoot.Position).Magnitude
                if dist <= nearestDist then nearestDist = dist; nearestTarget = player end
            end
        end
    end
    if nearestTarget then
        local targetPart = getTargetPart(nearestTarget.Character, Config.Aimbot.targetPriority)
        if targetPart then
            local targetPos = targetPart.Position
            if Config.KillAura.teleport then
                local targetRoot = nearestTarget.Character:FindFirstChild("HumanoidRootPart")
                local lookDir = targetRoot and targetRoot.CFrame.LookVector or (targetPos - root.Position).Unit
                local behindPos = targetPos + (-lookDir) * Config.KillAura.teleportOffset + Vector3.new(0, 3, 0)
                root.CFrame = CFrame.new(behindPos)
                root.Velocity = Vector3.new()
                targetPos = targetPart.Position
            end
            local camPos = Camera.CFrame.Position; local desiredCF = CFrame.new(camPos, targetPos)
            if Config.KillAura.useAimbot and Config.Aimbot.enabled then -- aimbot handles
            else Camera.CFrame = desiredCF end
            VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, true, game, 1); task.wait(0.02)
            VirtualInputManager:SendMouseButtonEvent(Mouse.X, Mouse.Y, 0, false, game, 1)
            if Config.KillAura.autoWalk then
                local direction = (targetPos - root.Position).Unit
                root.CFrame = root.CFrame + direction * Config.KillAura.walkSpeed * deltaTime; root.Velocity = Vector3.new(0,0,0)
            end
        end
    end
end

-- Anti‑Aim (Jitter/Spin/Random/Custom/Up/Down all work via BodyGyro)
local antiAimGyro = nil
local function updateAntiAim()
    if not Config.AntiAim.enabled or not LocalPlayer.Character then
        if antiAimGyro then antiAimGyro:Destroy(); antiAimGyro = nil end
        if aaArrow then aaArrow.Visible = false end
        return
    end
    local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if humanoid then humanoid.AutoRotate = false end
    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if not antiAimGyro or antiAimGyro.Parent ~= root then
        if antiAimGyro then antiAimGyro:Destroy() end
        antiAimGyro = Instance.new("BodyGyro"); antiAimGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9); antiAimGyro.Parent = root
    end
    local int = Config.AntiAim.intensity / 100
    local targetAngleY, targetAngleX = 0, 0
    if Config.AntiAim.type == "Spin" then
        targetAngleY = (os.clock() * Config.AntiAim.speed * int * 2*math.pi) % (2*math.pi)
    elseif Config.AntiAim.type == "Jitter" then
        targetAngleY = math.rad(math.random(-int*180, int*180))
    elseif Config.AntiAim.type == "Random" then
        targetAngleY = math.rad(math.random(-180, 180))
    elseif Config.AntiAim.type == "Custom" then
        targetAngleY = math.rad(Config.AntiAim.speed * int * 5)
        targetAngleX = math.rad(Config.AntiAim.pitch)
    elseif Config.AntiAim.type == "Up" then
        targetAngleX = math.rad(-90)
    elseif Config.AntiAim.type == "Down" then
        targetAngleX = math.rad(90)
    end
    antiAimGyro.CFrame = CFrame.new(root.Position) * CFrame.Angles(targetAngleX, targetAngleY, 0)
    if Config.AntiAim.visualizer then
        local pos2D, onScreen = worldToScreen(root.Position + Vector3.new(0,2,0))
        if onScreen then
            if not aaArrow then aaArrow = Drawing.new("Line"); aaArrow.Thickness = 2; aaArrow.Color = Color3.fromRGB(255,0,0) end
            aaArrow.Visible = true; local dir = root.CFrame.LookVector
            aaArrow.From = pos2D; aaArrow.To = Vector2.new(pos2D.X + dir.X*30, pos2D.Y - dir.Z*30)
        elseif aaArrow then aaArrow.Visible = false end
    elseif aaArrow then aaArrow.Visible = false end
    if Config.FakeLag.enabled then task.wait(Config.FakeLag.strength / 1000) end
end

-- Fly
local flyBodyGyro, flyBodyVelocity
local function startFly()
    local char = LocalPlayer.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    if flyBodyGyro then flyBodyGyro:Destroy() end; if flyBodyVelocity then flyBodyVelocity:Destroy() end
    flyBodyGyro = Instance.new("BodyGyro"); flyBodyGyro.MaxTorque = Vector3.new(9e9,9e9,9e9); flyBodyGyro.CFrame = root.CFrame; flyBodyGyro.Parent = root
    flyBodyVelocity = Instance.new("BodyVelocity"); flyBodyVelocity.MaxForce = Vector3.new(9e9,9e9,9e9); flyBodyVelocity.Velocity = Vector3.new(0,0,0); flyBodyVelocity.Parent = root
    if Config.Movement.fly.noclip then for _, part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end end
    task.spawn(function()
        while Config.Movement.fly.enabled and flyBodyVelocity do
            local move = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.yAxis end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.yAxis end
            flyBodyVelocity.Velocity = move * Config.Movement.fly.speed; flyBodyGyro.CFrame = Camera.CFrame; RunService.RenderStepped:Wait()
        end
    end)
end
local function stopFly()
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    if LocalPlayer.Character then for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = true end end end
end

