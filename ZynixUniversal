-- Watermark
local lastWatermarkUpdate = 0; local fpsCounter = 0; local lastFPS = tick(); local currentFPS = 60
local function updateWatermark()
    fpsCounter = fpsCounter + 1
    if tick() - lastFPS >= 1 then currentFPS = fpsCounter; fpsCounter = 0; lastFPS = tick() end
    if not Config.Misc.watermark then if watermarkText then watermarkText.Visible = false end return end
    if tick() - lastWatermarkUpdate < 0.5 then return end; lastWatermarkUpdate = tick()
    if not watermarkText then watermarkText = Drawing.new("Text"); watermarkText.Outline = true; watermarkText.Size = 18; watermarkText.Color = Color3.fromRGB(255,255,255) end
    watermarkText.Visible = true; watermarkText.Position = Vector2.new(10,10)
    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
    watermarkText.Text = string.format("Zynix | FPS: %d | Ping: %dms", currentFPS, ping)
end

