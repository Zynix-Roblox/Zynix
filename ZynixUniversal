-- Third Person
local shoulderSide = 1
local function updateThirdPerson(deltaTime)
    if not Config.Visuals.thirdPerson.enabled then return end
    local char = LocalPlayer.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local tp = Config.Visuals.thirdPerson
    local lookDir = Camera.CFrame.LookVector; local rightDir = Camera.CFrame.RightVector
    local shoulderOffset = rightDir * shoulderSide * tp.shoulderSide
    local desiredPos = root.Position - lookDir * tp.distance + Vector3.new(0, tp.height, 0) + shoulderOffset
    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(desiredPos, root.Position), math.min(1, 1 / tp.smoothness * deltaTime * 60))
    Camera.FieldOfView = tp.fov
end

