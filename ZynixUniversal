local function hideAllDrawings(d)
    if not d then return end
    for k, v in pairs(d) do
        if k == "skeletonLines" or k == "box3D_lines" then
            if type(v) == "table" then for _, line in ipairs(v) do if line and line.Visible then line.Visible = false end end end
        elseif type(v) == "userdata" and v.Visible then v.Visible = false end
    end
end

-- Compute screen‑space bounding box from all character parts
local function getCharacterScreenBounds(character)
    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local anyOnScreen = false
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then -- skip root itself to avoid huge box
            local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
            if onScreen then
                anyOnScreen = true
                if screenPos.X < minX then minX = screenPos.X end
                if screenPos.Y < minY then minY = screenPos.Y end
                if screenPos.X > maxX then maxX = screenPos.X end
                if screenPos.Y > maxY then maxY = screenPos.Y end
            end
        end
    end
    if not anyOnScreen then return nil end
    return Vector2.new(minX, minY), Vector2.new(maxX, maxY)
end

local R15_Joints = {
    {"Head","UpperTorso"}, {"UpperTorso","LowerTorso"}, {"LowerTorso","LeftUpperLeg"}, {"LeftUpperLeg","LeftLowerLeg"},
    {"LowerTorso","RightUpperLeg"}, {"RightUpperLeg","RightLowerLeg"}, {"UpperTorso","LeftUpperArm"}, {"LeftUpperArm","LeftLowerArm"},
    {"LeftLowerArm","LeftHand"}, {"UpperTorso","RightUpperArm"}, {"RightUpperArm","RightLowerArm"}, {"RightLowerArm","RightHand"}
}
local R6_Joints = {
    {"Head","Torso"}, {"Torso","Left Arm"}, {"Torso","Right Arm"}, {"Torso","Left Leg"}, {"Torso","Right Leg"}
}

local function updatePlayerESP(player)
    if not Config.Visuals.enabled then return end
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        hideAllDrawings(playerDrawings[player])
        return
    end
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not root or not head then return end

    -- distance filter
    if Config.Visuals.maxDistance > 0 then
        if (Camera.CFrame.Position - root.Position).Magnitude > Config.Visuals.maxDistance then
            hideAllDrawings(playerDrawings[player])
            return
        end
    end

    -- get precise screen bounds
    local boundsMin, boundsMax = getCharacterScreenBounds(char)
    if not boundsMin then
        hideAllDrawings(playerDrawings[player])
        return
    end

    local color = (player.Team == LocalPlayer.Team) and Config.Visuals.teamColor or Config.Visuals.enemyColor
    local d = ensureDrawingsForPlayer(player)

    -- 2D Box (uses accurate bounds)
    if d.box2D then
        local width = boundsMax.X - boundsMin.X
        local height = boundsMax.Y - boundsMin.Y
        d.box2D.Visible = true
        d.box2D.Position = boundsMin
        d.box2D.Size = Vector2.new(width, height)
        d.box2D.Color = color
        if d.box2DFill then
            d.box2DFill.Visible = true
            d.box2DFill.Position = boundsMin
            d.box2DFill.Size = Vector2.new(width, height)
            d.box2DFill.Color = color
            d.box2DFill.Transparency = Config.Visuals.box2DFillTransparency
        end
    end

    -- name, distance, health bar, etc. placed above the box
    local topCenter = Vector2.new((boundsMin.X + boundsMax.X)/2, boundsMin.Y)
    if d.name then d.name.Visible = true; d.name.Position = topCenter - Vector2.new(0, 20); d.name.Text = player.Name; d.name.Color = color end
    if d.distance then
        local dist = (Camera.CFrame.Position - root.Position).Magnitude
        d.distance.Visible = true; d.distance.Position = topCenter - Vector2.new(0, 38); d.distance.Text = string.format("%.1fm", dist); d.distance.Color = color
    end
    if d.healthBarBg and d.healthBarFill then
        local hp = humanoid.Health / humanoid.MaxHealth
        local barW = width; local barH = 4
        local barX = boundsMin.X; local barY = boundsMin.Y - 10
        d.healthBarBg.Visible = true; d.healthBarBg.Position = Vector2.new(barX, barY); d.healthBarBg.Size = Vector2.new(barW, barH)
        d.healthBarFill.Visible = true; d.healthBarFill.Position = Vector2.new(barX, barY); d.healthBarFill.Size = Vector2.new(barW*hp, barH)
        d.healthBarFill.Color = Color3.fromRGB(0,255,0):Lerp(Color3.fromRGB(255,0,0), 1 - hp)
    end
    if d.healthText then d.healthText.Visible = true; d.healthText.Position = topCenter - Vector2.new(0, 55); d.healthText.Text = tostring(math.floor(hp*100)).."%"; d.healthText.Color = color end

    -- Skeleton
    if d.skeletonLines then
        local rig = getRigType(char)
        local joints = rig == Enum.HumanoidRigType.R15 and R15_Joints or R6_Joints
        for i, joint in ipairs(joints) do
            if i <= #d.skeletonLines then
                local a = char:FindFirstChild(joint[1]); local b = char:FindFirstChild(joint[2])
                if a and b then
                    local sa,va = worldToScreen(a.Position); local sb,vb = worldToScreen(b.Position)
                    if va and vb then
                        d.skeletonLines[i].Visible = true; d.skeletonLines[i].From = sa; d.skeletonLines[i].To = sb; d.skeletonLines[i].Color = color
                    else d.skeletonLines[i].Visible = false end
                else d.skeletonLines[i].Visible = false end
            end
        end
        for i = #joints+1, #d.skeletonLines do d.skeletonLines[i].Visible = false end
    end

    -- Head Dot
    if d.headDot then
        local headPos, vis = worldToScreen(head.Position)
        d.headDot.Visible = vis; if vis then d.headDot.Position = headPos; d.headDot.Color = color end
    end

    -- Tracer
    if d.tracerLine then
        local headPos, vis = worldToScreen(head.Position)
        if vis then
            local origin = Config.Visuals.tracerOrigin == "Bottom" and Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y) or Vector2.new(Mouse.X, Mouse.Y)
            d.tracerLine.Visible = true; d.tracerLine.From = origin; d.tracerLine.To = headPos; d.tracerLine.Color = color
        else d.tracerLine.Visible = false end
    end
end

-- ESP update every frame (60 FPS) – extremely responsive
local function updateESP()
    if not Config.Visuals.enabled then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then safeCall(updatePlayerESP, player) end
    end
end

-- Crosshair
local function updateCrosshair()
    if not Config.Visuals.crosshair.enabled then
        for _, d in ipairs(crosshairDrawings) do d.Visible = false end
        return
    end
    local c = Config.Visuals.crosshair; local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    if #crosshairDrawings == 0 or crosshairDrawings[1].Style ~= c.style then
        for _, d in ipairs(crosshairDrawings) do d:Remove() end; crosshairDrawings = {}
        if c.style == "Cross" then for _=1,4 do table.insert(crosshairDrawings, Drawing.new("Line")) end
        elseif c.style == "Dot" then table.insert(crosshairDrawings, Drawing.new("Circle"))
        elseif c.style == "Circle" then table.insert(crosshairDrawings, Drawing.new("Circle"))
        elseif c.style == "Square" then table.insert(crosshairDrawings, Drawing.new("Square")) end
        if #crosshairDrawings > 0 then crosshairDrawings[1].Style = c.style end
    end
    if c.style == "Cross" then
        crosshairDrawings[1].From = Vector2.new(center.X - c.gap, center.Y); crosshairDrawings[1].To = Vector2.new(center.X - c.gap - c.length, center.Y)
        crosshairDrawings[2].From = Vector2.new(center.X + c.gap, center.Y); crosshairDrawings[2].To = Vector2.new(center.X + c.gap + c.length, center.Y)
        crosshairDrawings[3].From = Vector2.new(center.X, center.Y - c.gap); crosshairDrawings[3].To = Vector2.new(center.X, center.Y - c.gap - c.length)
        crosshairDrawings[4].From = Vector2.new(center.X, center.Y + c.gap); crosshairDrawings[4].To = Vector2.new(center.X, center.Y + c.gap + c.length)
        for _, d in ipairs(crosshairDrawings) do d.Color = c.color; d.Thickness = c.thickness; d.Visible = true end
    elseif c.style == "Dot" then local d = crosshairDrawings[1]; d.Position = center; d.Radius = 3; d.Color = c.color; d.Filled = true; d.Visible = true
    elseif c.style == "Circle" then local d = crosshairDrawings[1]; d.Position = center; d.Radius = 6; d.Color = c.color; d.Thickness = c.thickness; d.Filled = false; d.Visible = true
    elseif c.style == "Square" then local d = crosshairDrawings[1]; d.Position = Vector2.new(center.X-6, center.Y-6); d.Size = Vector2.new(12,12); d.Color = c.color; d.Thickness = c.thickness; d.Filled = false; d.Visible = true
    end
end

